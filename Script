#script
#Airlne schema based off figure 3.21 ER Diagram

DROP Database IF EXISTS AIRLINE;
CREATE Database AIRLINE;
USE AIRLINE;

#Airport

CREATE TABLE AIRPORT(
    AirportID VARCHAR(10) NOT NULL,
    Name VARCHAR(100) NOT NULL,
    City VARCHAR(50) NOT NULL,
    State VARCHAR(50) NOT NULL,
    CONSTRAINT PK_AIRPORT PRIMARY KEY (AirportID)
);

#Airplane_type 
CREATE TABLE AIRPLANE_TYPE(
    TypeName VARCHAR(50) NOT NULL,
    Company VARCHAR(100) NOT NULL,
    MaxPassengers INT NOT NULL,
    CONSTRAINT PK_AIRPLANE_TYPE PRIMARY KEY (TypeName)
);

#Landing

CREATE TABLE LANDING(
    AirportID VARCHAR(10) NOT NULL,
    TypeName VARCHAR(50) NOT NULL,
    CONSTRAINT PK_LANDING PRIMARY KEY (AirportID, TypeName),
    CONSTRAINT FK_LANDING_AIRPORT FOREIGN KEY (AirportID) REFERENCES AIRPORT(AirportID) ON UPDATE CASCADE ON DELETE CASCADE,
    CONSTRAINT FK_LANDING_AIRPLANE_TYPE FOREIGN KEY (TypeName) REFERENCES AIRPLANE_TYPE(TypeName) ON UPDATE CASCADE ON DELETE CASCADE
);

#Airplane

CREATE TABLE AIRPLANE(
    FlightID VARCHAR(20) NOT NULL,
    TotalSeats INT NOT NULL,
    TypeName VARCHAR(50) NOT NULL,
    CONSTRAINT PK_AIRPLANE_FLIGHT PRIMARY KEY (FlightID),
    CONSTRAINT FK_AIRPLANE_FLIGHT_AIRPLANE_TYPE FOREIGN KEY (TypeName) REFERENCES AIRPLANE_TYPE(TypeName) ON UPDATE CASCADE ON DELETE CASCADE
);

#Seat

CREATE TABLE SEAT(
    FlightID VARCHAR(20) NOT NULL,
    SeatNumber VARCHAR(10) NOT NULL,
    Class VARCHAR(30) NOT NULL,
    CONSTRAINT PK_SEAT PRIMARY KEY (FlightID, SeatNumber),
    CONSTRAINT FK_SEAT_AIRPLANE_FLIGHT FOREIGN KEY (FlightID) REFERENCES AIRPLANE_FLIGHT(FlightID) ON UPDATE CASCADE ON DELETE CASCADE
);

#Flight

CREATE TABLE FLIGHT(
    Number INT NOT NULL,
    Airline VARCHAR(100) NOT NULL,
    Weekdays CHAR(7) NOT NULL,
    Constraint PK_FLIGHT PRIMARY KEY (Number)
);

#Fare

CREATE TABLE FARE(
    FlightNumber INT NOT NULL,
    Class VARCHAR(30) NOT NULL,
    Price DECIMAL(10, 2) NOT NULL,
    CONSTRAINT PK_FARE PRIMARY KEY (FlightNumber, Class),
    CONSTRAINT FK_FARE_FLIGHT FOREIGN KEY (FlightNumber) REFERENCES FLIGHT(Number) ON UPDATE CASCADE ON DELETE CASCADE
);

#Flight_leg

CREATE TABLE FLIGHT_LEG(
    FlightNumber INT NOT NULL,
    LegNumber INT NOT NULL,
    DepartureAirportID VARCHAR(10) NOT NULL,
    ArrivalAirportID VARCHAR(10) NOT NULL,
    DepartureTime TIME NOT NULL,
    ArrivalTime TIME NOT NULL,
    CONSTRAINT PK_FLIGHT_LEG PRIMARY KEY (FlightNumber, LegNumber),
    CONSTRAINT FK_FLIGHT_LEG_FLIGHT FOREIGN KEY (FlightNumber) REFERENCES FLIGHT(Number) ON UPDATE CASCADE ON DELETE CASCADE,
    CONSTRAINT FK_FLIGHT_LEG_DEPARTURE_AIRPORT FOREIGN KEY (DepartureAirportID) REFERENCES AIRPORT(AirportID) ON UPDATE CASCADE ON DELETE CASCADE,
    CONSTRAINT FK_FLIGHT_LEG_ARRIVAL_AIRPORT FOREIGN KEY (ArrivalAirportID) REFERENCES AIRPORT(AirportID) ON UPDATE CASCADE ON DELETE CASCADE
);

#Leg_instance

CREATE TABLE LEG_INSTANCE(
    FlightNumber INT NOT NULL,
    LegNumber INT NOT NULL,
    Date DATE NOT NULL,
    AirplaneFlightID VARCHAR(20) NOT NULL,
    CONSTRAINT PK_LEG_INSTANCE PRIMARY KEY (FlightNumber, LegNumber, Date),
    CONSTRAINT FK_LEG_INSTANCE_FLIGHT_LEG FOREIGN KEY (FlightNumber, LegNumber) REFERENCES FLIGHT_LEG(FlightNumber, LegNumber) ON UPDATE CASCADE ON DELETE CASCADE,
    CONSTRAINT FK_LEG_INSTANCE_AIRPLANE_FLIGHT FOREIGN KEY (AirplaneFlightID) REFERENCES AIRPLANE_FLIGHT(FlightID) ON UPDATE CASCADE ON DELETE CASCADE
);

#Reservation

CREATE TABLE RESERVATION(
    FlightNumber INT NOT NULL,
    LegNumber INT NOT NULL,
    Date DATE NOT NULL,
    AirplaneFlightID VARCHAR(20) NOT NULL,
    SeatNumber VARCHAR(10) NOT NULL,
    PassengerName VARCHAR(100) NOT NULL,
    PhoneNumber VARCHAR(20) NOT NULL,
    CONSTRAINT PK_RESERVATION PRIMARY KEY (FlightNumber, LegNumber, Date, AirplaneFlightID,SeatNumber),
    CONSTRAINT FK_RESERVATION_LEG_INSTANCE FOREIGN KEY (FlightNumber, LegNumber, Date) REFERENCES LEG_INSTANCE(FlightNumber, LegNumber, Date) ON UPDATE CASCADE ON DELETE CASCADE,
    CONSTRAINT FK_RESERVATION_SEAT FOREIGN KEY (AirplaneFlightID, SeatNumber) REFERENCES SEAT(AirplaneFlightID, SeatNumber) ON UPDATE CASCADE ON DELETE CASCADE
);

